diff --git a/src/hardware/velleman/api.c b/src/hardware/velleman/api.c
new file mode 100644
index 00000000..61973dd8
--- /dev/null
+++ b/src/hardware/velleman/api.c
@@ -0,0 +1,264 @@
+/*
+ * This file is part of the libsigrok project.
+ *
+ * Minimal driver for Velleman LABPS series using text protocol
+ * terminated by literal characters "/n".
+ */
+
+#include <config.h>
+#include <glib.h>
+#include <libsigrok/libsigrok.h>
+#include <string.h>
+
+#include "libsigrok-internal.h"
+#include "protocol.h"
+
+#define VELLEMAN_SERIALCOMM "9600/8n1"
+
+/* Top-level driver option sets. */
+static const uint32_t scanopts[] = {
+    SR_CONF_CONN,
+    SR_CONF_SERIALCOMM,
+};
+
+static const uint32_t drvopts[] = {
+    SR_CONF_POWER_SUPPLY,
+};
+
+static const uint32_t devopts[] = {
+    SR_CONF_CONTINUOUS,
+};
+
+static const uint32_t devopts_cg[] = {
+    SR_CONF_VOLTAGE | SR_CONF_GET,
+    SR_CONF_VOLTAGE_TARGET | SR_CONF_GET | SR_CONF_SET | SR_CONF_LIST,
+    SR_CONF_CURRENT | SR_CONF_GET,
+    SR_CONF_CURRENT_LIMIT | SR_CONF_GET | SR_CONF_SET | SR_CONF_LIST,
+    SR_CONF_ENABLED | SR_CONF_GET | SR_CONF_SET,
+};
+
+struct dev_context {
+  vpsu_t dev; /* wraps serial */
+  /* Last known values (for quick get if STATUS parsing fails). */
+  double voltage_last;
+  double current_last;
+  gboolean output_enabled;
+
+  /* Ranges: min, max, step. LABPS3005DN is 0-30V, 0-5A. */
+  double v_range[3];
+  double i_range[3];
+};
+
+static gboolean parse_status_enabled(const char *s) {
+  if (!s)
+    return FALSE;
+  /* Heuristics: look for ON/1 vs OFF/0 near OUT keyword. */
+  if (g_strrstr(s, "OUT1:1") || g_strrstr(s, "OUT:1") || g_strrstr(s, "ON"))
+    return TRUE;
+  if (g_strrstr(s, "OUT1:0") || g_strrstr(s, "OUT:0") || g_strrstr(s, "OFF"))
+    return FALSE;
+  return FALSE;
+}
+
+static GSList *velleman_scan(struct sr_dev_driver *di, GSList *options) {
+  const char *conn = NULL;
+  const char *serialcomm = VELLEMAN_SERIALCOMM;
+  struct sr_serial_dev_inst *serial;
+  struct sr_dev_inst *sdi;
+  struct dev_context *devc;
+  char idn[128] = {0};
+
+  (void)sr_serial_extract_options(options, &conn, &serialcomm);
+  if (!conn)
+    return NULL;
+
+  serial = sr_serial_dev_inst_new(conn, serialcomm);
+  if (serial_open(serial, SERIAL_RDWR) != SR_OK) {
+    sr_serial_dev_inst_free(serial);
+    return NULL;
+  }
+
+  /* Probe with *IDN? (terminated by literal "/n" in protocol.c). */
+  devc = g_malloc0(sizeof(*devc));
+  devc->dev.ser = serial;
+  devc->v_range[0] = 0.0;
+  devc->v_range[1] = 30.0;
+  devc->v_range[2] = 0.01;
+  devc->i_range[0] = 0.0;
+  devc->i_range[1] = 5.0;
+  devc->i_range[2] = 0.001;
+
+  if (vpsu_idn(&devc->dev, idn, sizeof idn, serial_timeout(serial, 64)) != SR_OK) {
+    /* Not fatal: some FW may not support IDN. */
+    g_strlcpy(idn, "Velleman LABPS", sizeof idn);
+  }
+
+  sdi = g_malloc0(sizeof(*sdi));
+  sdi->status = SR_ST_INACTIVE;
+  sdi->vendor = g_strdup("Velleman");
+  /* If IDN looks like vendor,model,version..., split model. */
+  if (g_str_has_prefix(idn, "Velleman")) {
+    char **tok = g_strsplit(idn, ",", 4);
+    sdi->model = g_strdup(tok[1] ? tok[1] : "LABPS");
+    sdi->version = g_strdup(tok[2] ? tok[2] : NULL);
+    g_strfreev(tok);
+  } else {
+    sdi->model = g_strdup(idn);
+  }
+  sdi->inst_type = SR_INST_SERIAL;
+  sdi->conn = serial;
+  sdi->priv = devc;
+
+  /* Single output channel. */
+  sr_channel_new(sdi, 0, SR_CHANNEL_ANALOG, TRUE, "CH1");
+
+  serial_close(serial);
+  return std_scan_complete(di, g_slist_append(NULL, sdi));
+}
+
+static int config_get(uint32_t key, GVariant **data, const struct sr_dev_inst *sdi, const struct sr_channel_group *cg) {
+  struct dev_context *devc = sdi ? sdi->priv : NULL;
+  float f;
+  char stat[64];
+
+  if (!devc)
+    return SR_ERR_ARG;
+
+  switch (key) {
+  case SR_CONF_CONTINUOUS:
+    *data = g_variant_new_boolean(TRUE);
+    return SR_OK;
+  case SR_CONF_VOLTAGE:
+    if (vpsu_get_vout(&devc->dev, &f, serial_timeout(sdi->conn, 32)) == SR_OK) {
+      devc->voltage_last = f;
+      *data = g_variant_new_double(f);
+      return SR_OK;
+    }
+    return SR_ERR;
+  case SR_CONF_CURRENT:
+    if (vpsu_get_iout(&devc->dev, &f, serial_timeout(sdi->conn, 32)) == SR_OK) {
+      devc->current_last = f;
+      *data = g_variant_new_double(f);
+      return SR_OK;
+    }
+    return SR_ERR;
+  case SR_CONF_VOLTAGE_TARGET:
+    if (vpsu_get_vset(&devc->dev, &f, serial_timeout(sdi->conn, 32)) == SR_OK) {
+      *data = g_variant_new_double(f);
+      return SR_OK;
+    }
+    return SR_ERR;
+  case SR_CONF_CURRENT_LIMIT:
+    if (vpsu_get_iset(&devc->dev, &f, serial_timeout(sdi->conn, 32)) == SR_OK) {
+      *data = g_variant_new_double(f);
+      return SR_OK;
+    }
+    return SR_ERR;
+  case SR_CONF_ENABLED:
+    if (vpsu_cmd(&devc->dev, "STATUS?", stat, sizeof stat, serial_timeout(sdi->conn, 32)) == SR_OK) {
+      devc->output_enabled = parse_status_enabled(stat);
+    }
+    *data = g_variant_new_boolean(devc->output_enabled);
+    return SR_OK;
+  default:
+    return SR_ERR_NA;
+  }
+}
+
+static int config_set(uint32_t key, GVariant *data, const struct sr_dev_inst *sdi, const struct sr_channel_group *cg) {
+  struct dev_context *devc = sdi ? sdi->priv : NULL;
+  gdouble dval;
+  gboolean bval;
+
+  if (!devc)
+    return SR_ERR_ARG;
+
+  switch (key) {
+  case SR_CONF_VOLTAGE_TARGET:
+    dval = g_variant_get_double(data);
+    if (dval < devc->v_range[0] || dval > devc->v_range[1])
+      return SR_ERR_ARG;
+    return vpsu_set_v(&devc->dev, (float)dval);
+  case SR_CONF_CURRENT_LIMIT:
+    dval = g_variant_get_double(data);
+    if (dval < devc->i_range[0] || dval > devc->i_range[1])
+      return SR_ERR_ARG;
+    return vpsu_set_i(&devc->dev, (float)dval);
+  case SR_CONF_ENABLED:
+    bval = g_variant_get_boolean(data);
+    devc->output_enabled = bval;
+    return vpsu_output(&devc->dev, bval);
+  default:
+    return SR_ERR_NA;
+  }
+}
+
+static int config_list(uint32_t key, GVariant **data, const struct sr_dev_inst *sdi,
+                       const struct sr_channel_group *cg) {
+  struct dev_context *devc = (sdi) ? sdi->priv : NULL;
+
+  if (!cg) {
+    switch (key) {
+    case SR_CONF_SCAN_OPTIONS:
+    case SR_CONF_DEVICE_OPTIONS:
+      return STD_CONFIG_LIST(key, data, sdi, cg, scanopts, drvopts, devopts);
+    default:
+      return SR_ERR_NA;
+    }
+  } else {
+    switch (key) {
+    case SR_CONF_DEVICE_OPTIONS:
+      *data = std_gvar_array_u32(ARRAY_AND_SIZE(devopts_cg));
+      return SR_OK;
+    case SR_CONF_VOLTAGE_TARGET:
+      if (!devc)
+        return SR_ERR_ARG;
+      *data = std_gvar_min_max_step_array(devc->v_range);
+      return SR_OK;
+    case SR_CONF_CURRENT_LIMIT:
+      if (!devc)
+        return SR_ERR_ARG;
+      *data = std_gvar_min_max_step_array(devc->i_range);
+      return SR_OK;
+    default:
+      return SR_ERR_NA;
+    }
+  }
+}
+
+static int dev_open(struct sr_dev_inst *sdi) {
+  struct dev_context *devc = sdi->priv;
+  int ret = std_serial_dev_open(sdi);
+  if (ret == SR_OK)
+    devc->dev.ser = sdi->conn;
+  return ret;
+}
+
+static int dev_close(struct sr_dev_inst *sdi) { return std_serial_dev_close(sdi); }
+
+static int dev_acquisition_start(const struct sr_dev_inst *sdi) {
+  /* No streamed frames for now; values can be polled via config_get. */
+  std_session_send_df_header(sdi);
+  return SR_OK;
+}
+
+static struct sr_dev_driver velleman_psu_driver_info = {
+    .name = "velleman-psu",
+    .longname = "Velleman LABPS power supply",
+    .api_version = 1,
+    .init = std_init,
+    .cleanup = std_cleanup,
+    .scan = velleman_scan,
+    .dev_list = std_dev_list,
+    .dev_clear = std_dev_clear,
+    .config_get = config_get,
+    .config_set = config_set,
+    .config_list = config_list,
+    .dev_open = dev_open,
+    .dev_close = dev_close,
+    .dev_acquisition_start = dev_acquisition_start,
+    .dev_acquisition_stop = std_serial_dev_acquisition_stop,
+    .context = NULL,
+};
+
+SR_REGISTER_DEV_DRIVER(velleman_psu_driver_info);
diff --git a/src/hardware/velleman/protocol.c b/src/hardware/velleman/protocol.c
new file mode 100644
index 00000000..8f2031aa
--- /dev/null
+++ b/src/hardware/velleman/protocol.c
@@ -0,0 +1,66 @@
+#include <config.h>
+
+#include "libsigrok-internal.h"
+#include "protocol.h"
+#include <glib.h>
+#include <libsigrok/libsigrok.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+static int read_until_term(vpsu_t *d, char *buf, size_t n, int to_ms) {
+  size_t i = 0;
+  while (i + 1 < n) {
+    uint8_t b;
+    int r = serial_read_blocking(d->ser, &b, 1, to_ms);
+    if (r <= 0)
+      return SR_ERR_TIMEOUT;
+    buf[i++] = (char)b;
+    if (i >= 2 && buf[i - 2] == '/' && buf[i - 1] == 'n') {
+      i -= 2;
+      break;
+    }
+  }
+  buf[i] = 0;
+  return SR_OK;
+}
+
+int vpsu_cmd(vpsu_t *d, const char *cmd, char *resp, size_t n, int to_ms) {
+  if (!d || !d->ser || !cmd)
+    return SR_ERR_ARG;
+  serial_flush(d->ser);
+  if (serial_write_blocking(d->ser, cmd, strlen(cmd), (unsigned int)(to_ms ? to_ms : 1000)) < 0)
+    return SR_ERR;
+  if (serial_write_blocking(d->ser, "/n", 2, (unsigned int)(to_ms ? to_ms : 1000)) < 0)
+    return SR_ERR;
+  if (!resp || !n)
+    return SR_OK;
+  return read_until_term(d, resp, n, to_ms);
+}
+
+static int qf(vpsu_t *d, const char *cmd, float *out, int to) {
+  char b[64];
+  int r = vpsu_cmd(d, cmd, b, sizeof b, to);
+  if (r < 0)
+    return r;
+  *out = strtof(b, NULL);
+  return SR_OK;
+}
+static int sf(vpsu_t *d, const char *fmt, float x) {
+  char b[64];
+  snprintf(b, sizeof b, fmt, x);
+  return vpsu_cmd(d, b, NULL, 0, 0);
+}
+
+int vpsu_idn(vpsu_t *d, char *r, size_t n, int to) { return vpsu_cmd(d, "*IDN?", r, n, to); }
+int vpsu_set_v(vpsu_t *d, float v) { return sf(d, "VSET1:%0.2f", v); }
+int vpsu_set_i(vpsu_t *d, float a) { return sf(d, "ISET1:%0.3f", a); }
+int vpsu_get_vset(vpsu_t *d, float *out, int to) { return qf(d, "VSET1?", out, to); }
+int vpsu_get_iset(vpsu_t *d, float *out, int to) { return qf(d, "ISET1?", out, to); }
+int vpsu_get_vout(vpsu_t *d, float *out, int to) { return qf(d, "VOUT1?", out, to); }
+int vpsu_get_iout(vpsu_t *d, float *out, int to) { return qf(d, "IOUT1?", out, to); }
+int vpsu_output(vpsu_t *d, int enable) {
+  char b[24];
+  snprintf(b, sizeof b, "OUTPUT1:%d", !!enable);
+  return vpsu_cmd(d, b, NULL, 0, 0);
+}
